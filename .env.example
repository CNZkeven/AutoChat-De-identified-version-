# Postgres
POSTGRES_DB=autochat
POSTGRES_USER=autochat
POSTGRES_PASSWORD=autochat
POSTGRES_PORT=5432

# Service ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Backend
DATABASE_URL=postgresql+psycopg://autochat:autochat@db:5432/autochat
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=change-this-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
VITE_ALLOW_GUEST=true

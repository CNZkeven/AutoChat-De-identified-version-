# Postgres
POSTGRES_DB=autochat
POSTGRES_USER=autochat
POSTGRES_PASSWORD=autochat
POSTGRES_PORT=5433

# Service ports
BACKEND_PORT=8000
FRONTEND_PORT=5174

# Backend
DATABASE_URL=postgresql+psycopg://autochat:autochat@db:5432/autochat
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
JWT_SECRET_KEY=change-this-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Achieve 数据同步（内部读库）
# 例：postgresql://readonly:password@127.0.0.1:5433/course_analysis_db
ACHIEVE_DB_DSN=
SYNC_TERM_WINDOW=
SYNC_BATCH_SIZE=2000
SYNC_SCHEDULE_CRON=0 3 * * *

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
VITE_ALLOW_GUEST=true

# CORS
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# Redis
REDIS_URL=redis://localhost:6379/0

